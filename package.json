{
  "name": "STC",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "gen:snapshots": "bun run scripts/gen-snapshot-fixtures.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@xyflow/react": "12",
    "elkjs": "^0.11.1",
    "fraction.js": "^5.3.4",
    "react": "19",
    "react-dom": "19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "5",
    "eslint": "9",
    "eslint-plugin-react": "7",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "5",
    "typescript-eslint": "^8.59.2",
    "vite": "7",
    "vitest": "^4.1.5"
  }
}
